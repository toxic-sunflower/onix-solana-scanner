DB_PASSWORD=your_password_here
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_BOT_USERNAME=OnixSolanaScanner_Bot
ENCRYPTION_KEY=your_base64_key_here
APP_URL=http://localhost:5000
# "Log In With Telegram" OAuth2/PKCE — from BotFather > Bot Settings > Web Login.
# RedirectUri must match exactly what you registered there (e.g. https://yourapp.com/).
TELEGRAM_OAUTH_CLIENT_ID=your_bot_numeric_client_id
TELEGRAM_OAUTH_CLIENT_SECRET=your_client_secret_here
TELEGRAM_OAUTH_REDIRECT_URI=http://localhost:5000/
# Any random string you generate yourself (e.g. `openssl rand -hex 32`) — not
# something Telegram gives you. Verified against the X-Telegram-Bot-Api-Secret-Token
# header on incoming webhook requests so random internet traffic can't post fake updates.
TELEGRAM_WEBHOOK_SECRET=generate_a_random_secret_here
